# ──────────────────────────────────────────────────────────────
# Weights & Biases (W&B) — experiment tracking
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values. `.env` is
# gitignored so your key never ends up in the repo.
#
# Get your key: https://wandb.ai/authorize
#
# When running in CI (e.g. GitHub Actions), set these as repository
# secrets — the workflow will surface them as env vars at runtime.

# REQUIRED — API key for your W&B account
WANDB_API_KEY=your-wandb-api-key-here

# OPTIONAL — project name (a new project is created if it doesn't exist)
WANDB_PROJECT=ds4e-final-project

# OPTIONAL — team / user entity; leave blank to use your default entity
WANDB_ENTITY=

# OPTIONAL — "online" (default), "offline" (cache locally), or "disabled"
WANDB_MODE=online
